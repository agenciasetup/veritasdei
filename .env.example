# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Community (feature flags)
NEXT_PUBLIC_FEATURE_COMMUNITY_ENABLED=true
NEXT_PUBLIC_FEATURE_COMMUNITY_PUBLIC_PROFILES=true
NEXT_PUBLIC_FEATURE_COMMUNITY_REPLIES=true

# Community media (Cloudflare R2 + Image Transformations)
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=veritas-media-prod
CF_R2_PUBLIC_BASE_URL=https://media.veritasdei.com.br

# OpenAI
OPENAI_API_KEY=

# App — MUST be set in production (e.g. https://veritasdei.com.br)
# Controls OAuth redirect URLs, email links, and password reset redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (VAPID) — gerados via `node scripts/generate-vapid.mjs`
# PUBLIC é enviado pro cliente (PushManager.subscribe), PRIVATE fica só no
# server (Edge Function send-push). O e-mail é obrigatório por spec (rfc8292).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@veritasdei.com.br

# Firebase Cloud Messaging (FCM) — push nativo no app empacotado
# (Capacitor Android/iOS). Web continua usando VAPID acima; FCM atende
# os usuários que abriram o app shell.
#
# Como gerar:
#   1. Console Firebase ▸ Project Settings ▸ Service Accounts.
#   2. "Generate new private key" — baixa um JSON.
#   3. Cole TUDO o conteúdo do JSON aqui (uma única linha; service_account
#      é um objeto com project_id, private_key, client_email etc.).
#
# IMPORTANTE: cuidado pra não comitar nem expor — esta credencial
# permite enviar push em nome do projeto Firebase. Vercel ENV VAR
# only; nunca em código.
FIREBASE_SERVICE_ACCOUNT=

# Stripe — billing (Fase 3)
# - SECRET_KEY: chave privada do dashboard (sk_test_... ou sk_live_...)
# - PUBLISHABLE_KEY: opcional no server; útil no client se quiser usar Stripe.js
# - WEBHOOK_SECRET: criado ao registrar o endpoint em
#   https://dashboard.stripe.com/webhooks (whsec_...)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Outros gateways (opcional) — cada um valida x-webhook-secret
KIRVANO_WEBHOOK_SECRET=
HOTMART_WEBHOOK_SECRET=
EDUZZ_WEBHOOK_SECRET=

# Hubla — gateway do subproduto Veritas Educa.
# - WEBHOOK_TOKEN: string que VOCÊ define no painel Hubla ▸ Configurações ▸
#   Webhooks. A Hubla envia esse mesmo valor no header `x-hubla-token`
#   em toda requisição; /api/payments/webhooks/hubla compara em tempo
#   constante. Gere com `openssl rand -hex 32`.
# - PRODUCT_ID_VERITAS_EDUCA: UUID do produto criado no painel Hubla.
#   Encontrado na URL da página do produto (ex.: /produtos/<UUID>).
#   Mapeamos esse productId → plano `veritas-educa` no nosso banco.
# - CHECKOUT_URL_VERITAS_EDUCA: URL pública do checkout da oferta
#   (ex.: https://pay.hubla.com.br/<offer-id>). Recebe ?email= e ?name=
#   como query params pra pré-preencher o checkout.
#   Exposta também com prefixo NEXT_PUBLIC_ pra uso no client.
HUBLA_WEBHOOK_TOKEN=
HUBLA_PRODUCT_ID_VERITAS_EDUCA=
HUBLA_CHECKOUT_URL_VERITAS_EDUCA=
NEXT_PUBLIC_HUBLA_CHECKOUT_URL_VERITAS_EDUCA=

# RevenueCat — pagamentos no app empacotado (Capacitor Android/iOS).
# Web continua via Stripe; RevenueCat é só ativado quando o usuário
# está no shell nativo (Capacitor.isNativePlatform()).
# - PUBLIC_KEY_ANDROID/IOS: SDK key públicas (RevenueCat Dashboard ▸
#   Project ▸ API Keys). Em dev usar test_…; em prod, goog_… e appl_….
#   Como o SDK roda no client, exposição via NEXT_PUBLIC_ é por design.
# - SECRET_API_KEY: server-only (sk_…). Usado para chamadas REST
#   admin (sem uso obrigatório hoje, mas reservado).
# - WEBHOOK_SECRET: string aleatória que VOCÊ gera (`openssl rand -hex 32`)
#   e cola no painel RevenueCat ▸ Integrations ▸ Webhooks ▸ Authorization
#   Header. /api/payments/webhooks/revenuecat compara em tempo constante.
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY_ANDROID=
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY_IOS=
REVENUECAT_SECRET_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# Upstash Redis (rate limiter distribuído) — opcional mas RECOMENDADO
# em produção.
# Sem isso, o rate limiter cai para in-memory per-instance. No Vercel,
# cold starts criam múltiplas instâncias, então o limiter local é
# contornado em escala — atacante distribui requests entre instâncias.
# Provisione em https://upstash.com → Create Database → região próxima
# do Vercel region (us-east-2 pro projeto atual). O free tier cobre o
# tráfego inicial. Copie REST URL + REST TOKEN do console Upstash.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Webhook / cron secret — obrigatório em produção quando cron está ativo.
# Vercel Cron envia `Authorization: Bearer ${CRON_SECRET}` se você
# definir o header no vercel.json; a rota /api/novenas/reminders valida.
CRON_SECRET=

# Cloudflare Turnstile (anti-bot) — obrigatório em produção pra rota
# pública /api/paroquias/publico e formulário /paroquias/sugerir.
# Provisione em https://dash.cloudflare.com/?to=/:account/turnstile.
# SITE_KEY é público (client); SECRET_KEY só server.
# Em dev, sem essas vars o sistema aceita submissões sem verificação.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
